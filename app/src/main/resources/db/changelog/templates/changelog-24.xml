<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.27.xsd">

    <changeSet id="24-create-batch-generation" author="system">
        <comment>Batch AI generation history</comment>
        <createTable tableName="batch_generation">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false" primaryKeyName="pk_batch_generation"/>
            </column>
            <column name="user_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="user_input" type="TEXT">
                <constraints nullable="false"/>
            </column>
            <column name="plan_json" type="TEXT">
                <constraints nullable="false"/>
            </column>
            <column name="status" type="VARCHAR(20)">
                <constraints nullable="false"/>
            </column>
            <column name="lesson_id" type="BIGINT"/>
            <column name="total_steps" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="error_message" type="TEXT"/>
            <column name="created_at" type="DATETIME">
                <constraints nullable="false"/>
            </column>
            <column name="completed_at" type="DATETIME"/>
        </createTable>

        <addForeignKeyConstraint
                baseTableName="batch_generation"
                baseColumnNames="user_id"
                referencedTableName="users"
                referencedColumnNames="id"
                constraintName="fk_batch_generation_user"/>

        <addForeignKeyConstraint
                baseTableName="batch_generation"
                baseColumnNames="lesson_id"
                referencedTableName="lessons"
                referencedColumnNames="id"
                constraintName="fk_batch_generation_lesson"/>

        <createIndex indexName="idx_batch_generation_user_created" tableName="batch_generation">
            <column name="user_id"/>
            <column name="created_at"/>
        </createIndex>

        <createIndex indexName="idx_batch_generation_status" tableName="batch_generation">
            <column name="status"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
