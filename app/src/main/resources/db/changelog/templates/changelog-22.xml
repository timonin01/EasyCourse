<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.27.xsd">

    <changeSet id="22-create-ai-session" author="system">
        <comment>AI chat and step-generation sessions</comment>
        <createTable tableName="ai_session">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false" primaryKeyName="pk_ai_session"/>
            </column>
            <column name="user_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="session_id" type="VARCHAR(64)">
                <constraints nullable="false"/>
            </column>
            <column name="chat_type" type="VARCHAR(20)">
                <constraints nullable="false"/>
            </column>
            <column name="step_type" type="VARCHAR(30)"/>
            <column name="title" type="VARCHAR(255)"/>
            <column name="created_at" type="DATETIME">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="DATETIME">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addForeignKeyConstraint
                baseTableName="ai_session"
                baseColumnNames="user_id"
                referencedTableName="users"
                referencedColumnNames="id"
                constraintName="fk_ai_session_user"/>

        <addUniqueConstraint
                tableName="ai_session"
                columnNames="session_id"
                constraintName="uk_ai_session_session_id"/>

        <createIndex indexName="idx_ai_session_user_type_updated" tableName="ai_session">
            <column name="user_id"/>
            <column name="chat_type"/>
            <column name="updated_at"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
